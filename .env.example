VITE_POCKETBASE_URL=http://127.0.0.1:8092
VITE_APP_URL=http://localhost:5173
VITE_BANXICO_RATE_ENDPOINT=http://127.0.0.1:8092/api/electroprice/rates/usd-mxn
VITE_VHUB_BASE_URL=http://127.0.0.1:8787
VITE_VIMPORT_BASE_URL=http://127.0.0.1:8788
VITE_SUBSHOPPING_LIVE_RUNTIME=false
VITE_ENABLE_SANDBOX_PAYMENTS=true
VITE_ENABLE_SUBSHOPPING_SANDBOX=true

# Browser AI keys are disabled by default. Use only for local experiments.
VITE_ALLOW_BROWSER_AI_KEY=false

# Google sign-in (independent of PocketBase). Set the OAuth client id in the
# browser bundle; set the SAME id server-side as PBM_GOOGLE_CLIENT_ID so the V
# backend can verify the Google ID token audience.
VITE_GOOGLE_CLIENT_ID=
# PBM_GOOGLE_CLIENT_ID is set in the V backend host env (shared/env/vbackend.env)

# Server-side only; set this in the PocketBase host environment, not in browser bundles.
BANXICO_API_TOKEN=your_banxico_sie_token_here
GEMINI_API_KEY=your_gemini_api_key_here
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=replace_with_a_strong_password
