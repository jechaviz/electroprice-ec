      "aiSpec": "config/providers/api_integrator/cva_ai.yaml",
      "vimportSpec": "config/providers/vimport/mexico_provider_cva_portal.yml",
      "secretRefs": ["CVA_USER", "CVA_PASSWORD", "CVA_API_TOKEN", "CVA_GUIDES_TOKEN", "CVA_PORTAL_USER", "CVA_PORTAL_PASSWORD"],
      "capabilities": ["catalog", "price", "stock", "product_content", "images", "orders", "waybills"]
