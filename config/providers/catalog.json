{
  "version": "0.5.0",
  "owner": "electroprice-ec",
  "providerConfigRoot": "config/providers",
  "runtime": {
    "frontend": "electroprice-ec",
    "backend": "pocketbase+vhub",
    "apiSpecRuntime": "vhub",
    "portalFallbackRuntime": "vimport",
    "secretStore": "server_env_only",
    "vhubBaseUrlEnv": "VITE_VHUB_BASE_URL",
    "vimportBaseUrlEnv": "VITE_VIMPORT_BASE_URL"
  },
  "policy": {
    "browserSecretsAllowed": false,
    "frontendReadsSecrets": false,
    "realTimePriceOwner": "vhub",
    "portalAutomationOwner": "vimport",
    "credentialTemplate": "config/providers/vimport/mexico_provider_credentials.env.example"
  },
  "integrations": [
